# CAM-PI Environment Variables
# Copy to .env and adjust values

# GitHub repo for auto-update
GITHUB_REPO=lsduarte16/centinelacam

# Camera RTSP (overrides settings.yaml)
CAMERA_RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1

# Cloud sync credentials (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Ollama (if remote)
OLLAMA_HOST=http://localhost:11434
